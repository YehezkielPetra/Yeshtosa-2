<% layout('layouts/main') -%>

<div class="max-w-2xl">
  <div class="panel p-5">
    <form action="/pembelian/tambah" method="POST" class="space-y-4" id="form-pembelian">
      <div>
        <label class="label-field">Supplier</label>
        <select name="supplier_id" required class="input-field">
          <option value="">Pilih supplier...</option>
          <% supplierList.forEach(s => { %>
            <option value="<%= s.id %>"><%= s.nomor_supplier %> · <%= s.nama %></option>
          <% }) %>
        </select>
      </div>

      <div>
        <label class="label-field">Item Bahan Baku</label>
        <div id="item-container" class="space-y-2"></div>
        <button type="button" onclick="tambahItem()" class="text-clay text-xs font-medium mt-2 hover:underline">+ Tambah bahan baku</button>
      </div>

      <div class="bg-cream rounded-md p-4 border border-line">
        <div class="flex justify-between text-sm"><span class="text-ink/60">Total Pembelian</span><span id="display-total" class="font-display font-semibold text-clay text-lg">Rp0</span></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="label-field">Jumlah Dibayar Sekarang (Rp)</label>
          <input type="number" step="0.01" name="total_dibayar" id="total_dibayar" class="input-field" value="0">
        </div>
        <div>
          <label class="label-field">Status Bayar</label>
          <input type="text" id="display-status-bayar" class="input-field bg-line/30" readonly value="Belum Bayar">
          <input type="hidden" name="status_bayar" id="status_bayar" value="belum_bayar">
        </div>
      </div>

      <div>
        <label class="label-field">Catatan</label>
        <textarea name="catatan" rows="2" class="input-field"></textarea>
      </div>

      <div class="flex gap-3 pt-2">
        <button type="submit" class="btn-primary">Simpan Pembelian</button>
        <a href="/pembelian" class="btn-secondary">Batal</a>
      </div>
    </form>
  </div>
</div>

<script>
  const BAHAN_LIST = <%- JSON.stringify(bahanList) %>;
  function bahanOptionsHtml() {
    return '<option value="">Pilih bahan baku...</option>' + BAHAN_LIST.map(b => `<option value="${b.id}">${b.nama_bahan} (${b.satuan})</option>`).join('');
  }
  function tambahItem() {
    const container = document.getElementById('item-container');
    const div = document.createElement('div');
    div.className = 'flex gap-2 items-center item-row';
    div.innerHTML = `
      <select name="bahan_baku_id" class="input-field flex-1 bahan-select" onchange="updateTotal()">${bahanOptionsHtml()}</select>
      <input type="number" step="0.01" name="jumlah" min="0.01" value="1" class="input-field w-24 jumlah-input" oninput="updateTotal()">
      <input type="number" step="0.01" name="harga_satuan" placeholder="Harga satuan" class="input-field w-32 harga-input" oninput="updateTotal()">
      <button type="button" onclick="this.closest('.item-row').remove(); updateTotal()" class="text-warn text-sm px-2">✕</button>
    `;
    container.appendChild(div);
  }
  function updateTotal() {
    let total = 0;
    document.querySelectorAll('.item-row').forEach(row => {
      const jumlah = Number(row.querySelector('.jumlah-input').value) || 0;
      const harga = Number(row.querySelector('.harga-input').value) || 0;
      total += jumlah * harga;
    });
    document.getElementById('display-total').textContent = 'Rp' + Math.round(total).toLocaleString('id-ID');
    updateStatusBayar(total);
  }
  function updateStatusBayar(total) {
    const dibayar = Number(document.getElementById('total_dibayar').value) || 0;
    let status = 'belum_bayar', label = 'Belum Bayar';
    if (dibayar >= total && total > 0) { status = 'lunas'; label = 'Lunas'; }
    else if (dibayar > 0 && dibayar < total) { status = 'sebagian'; label = 'Sebagian'; }
    document.getElementById('status_bayar').value = status;
    document.getElementById('display-status-bayar').value = label;
  }
  document.getElementById('total_dibayar').addEventListener('input', () => {
    const totalText = document.getElementById('display-total').textContent.replace(/[^0-9]/g, '');
    updateStatusBayar(Number(totalText) || 0);
  });
  tambahItem();
</script>
