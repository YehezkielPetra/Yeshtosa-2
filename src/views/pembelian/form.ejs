<% layout('layouts/main') -%>

<div class="max-w-2xl">
  <% if (typeof isAdminPengajuan !== 'undefined' && isAdminPengajuan) { %>
    <div class="rounded-md bg-clay/10 border border-clay/30 text-clay-dark px-4 py-2.5 text-sm mb-4">
      Perubahan yang Anda simpan tidak langsung berlaku. Permohonan akan masuk antrean persetujuan dan menunggu keputusan Owner.
    </div>
  <% } %>

  <div class="panel p-5">
    <form action="<%= (typeof isEdit !== 'undefined' && isEdit) ? `/pembelian/${pembelian.id}/edit` : '/pembelian/tambah' %>" method="POST" class="space-y-4" id="form-pembelian">
      <div>
        <label class="label-field">Supplier</label>
        <div class="combo-wrap" data-name="supplier_id">
          <input type="text" class="input-field combo-input" placeholder="Cari nama atau no. supplier..." autocomplete="off">
          <input type="hidden" name="supplier_id" id="supplier_id" class="combo-value" required>
          <div class="combo-dropdown hidden"></div>
        </div>
      </div>

      <div>
        <label class="label-field">Item Bahan Baku</label>
        <div id="pesan-belum-pilih-supplier" class="text-xs text-ink/40 mb-2">Pilih supplier terlebih dahulu untuk menampilkan daftar item yang dipasoknya.</div>
        <div id="pesan-supplier-kosong" class="text-xs text-warn mb-2 hidden">Supplier ini belum memiliki item bahan baku.</div>
        <div id="item-container" class="space-y-2"></div>
        <button type="button" id="btn-tambah-item" onclick="tambahItem()" class="text-clay text-xs font-medium mt-2 hover:underline hidden">+ Tambah bahan baku</button>
      </div>

      <div class="bg-cream rounded-md p-4 border border-line">
        <div class="flex justify-between text-sm"><span class="text-ink/60">Total Pembelian</span><span id="display-total" class="font-display font-semibold text-clay text-lg">Rp0</span></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="label-field">Jumlah Dibayar Sekarang (Rp)</label>
          <input type="number" step="0.01" name="total_dibayar" id="total_dibayar" class="input-field" value="<%= (typeof pembelian !== 'undefined' && pembelian) ? pembelian.total_dibayar : 0 %>">
        </div>
        <div>
          <label class="label-field">Status Bayar</label>
          <input type="text" id="display-status-bayar" class="input-field bg-line/30" readonly value="Belum Bayar">
          <input type="hidden" name="status_bayar" id="status_bayar" value="belum_bayar">
        </div>
      </div>

      <div>
        <label class="label-field">Catatan</label>
        <textarea name="catatan" rows="2" class="input-field"><%= (typeof pembelian !== 'undefined' && pembelian && pembelian.catatan) ? pembelian.catatan : '' %></textarea>
      </div>

      <% if (typeof isAdminPengajuan !== 'undefined' && isAdminPengajuan) { %>
        <div>
          <label class="label-field">Alasan Perubahan</label>
          <textarea name="alasan_perubahan" rows="2" class="input-field" placeholder="Jelaskan alasan pengajuan perubahan ini..." required></textarea>
        </div>
      <% } %>

      <div class="flex gap-3 pt-2">
        <% if (typeof isEdit !== 'undefined' && isEdit) { %>
          <% if (typeof isAdminPengajuan !== 'undefined' && isAdminPengajuan) { %>
            <button type="submit" class="btn-primary">Ajukan Edit Pembelian</button>
          <% } else { %>
            <button type="submit" class="btn-primary">Simpan Perubahan</button>
          <% } %>
          <a href="/pembelian/<%= pembelian.id %>" class="btn-secondary">Batal</a>
        <% } else { %>
          <button type="submit" class="btn-primary">Simpan Pembelian</button>
          <a href="/pembelian" class="btn-secondary">Batal</a>
        <% } %>
      </div>
    </form>
  </div>
</div>

<script>
  const SUPPLIER_LIST = <%- JSON.stringify(supplierList) %>;
  const BAHAN_LIST = <%- JSON.stringify(bahanList) %>;
  const SUPPLIER_BAHAN_LIST = <%- JSON.stringify(supplierBahanList) %>;
  const IS_EDIT = <%- (typeof isEdit !== 'undefined' && isEdit) ? 'true' : 'false' %>;
  const PEMBELIAN_AWAL = <%- (typeof pembelian !== 'undefined' && pembelian) ? JSON.stringify({
    supplier_id: pembelian.supplier_id,
    total_dibayar: pembelian.total_dibayar,
    status_bayar: pembelian.status_bayar,
    detail: (pembelian.pembelian_detail || []).map(d => ({ bahan_baku_id: d.bahan_baku_id, jumlah: d.jumlah, harga_satuan: d.harga_satuan })),
  }) : 'null' %>;
  let itemCount = 0;
  let supplierTerpilihId = PEMBELIAN_AWAL ? PEMBELIAN_AWAL.supplier_id : null;

  // --- Combobox Supplier ---
  const supplierItems = SUPPLIER_LIST.map(s => ({
    id: s.id,
    label: `${s.nomor_supplier} · ${s.nama}`,
    searchText: `${s.nomor_supplier} ${s.nama}`,
  }));
  initCombobox(document.querySelector('[data-name="supplier_id"]'), supplierItems, {
    initialId: supplierTerpilihId || null,
    onSelect(item) {
      const supplierBerubah = supplierTerpilihId !== item.id;
      supplierTerpilihId = item.id;
      onSupplierBerubah(supplierBerubah);
    },
  });

  /**
   * Mengambil daftar item bahan baku (siap untuk combobox) yang
   * hanya dipasok oleh supplier tertentu, berdasarkan relasi di
   * tabel supplier_bahan_baku. Jika supplier belum punya relasi
   * item apapun, kembalikan array kosong.
   */
  function bahanItemsUntukSupplier(supplierId) {
    const bahanIdsUntukSupplier = SUPPLIER_BAHAN_LIST
      .filter(sb => sb.supplier_id === supplierId)
      .map(sb => sb.bahan_baku_id);

    return BAHAN_LIST
      .filter(b => bahanIdsUntukSupplier.includes(b.id))
      .map(b => ({
        id: b.id,
        label: `${b.nama_bahan} (${b.satuan})`,
        searchText: `${b.nama_bahan} ${b.kode_bahan || ''}`,
      }));
  }

  /**
   * Dipanggil setiap kali supplier yang dipilih berubah. Daftar item
   * pada SEMUA baris yang sudah ada diperbarui otomatis agar hanya
   * menampilkan item milik supplier tersebut. Baris item lama HANYA
   * direset jika supplier benar-benar berganti (bukan saat prefill
   * awal formulir edit dengan supplier yang sama).
   */
  function onSupplierBerubah(supplierBerubah) {
    const bahanItemsBaru = bahanItemsUntukSupplier(supplierTerpilihId);

    document.getElementById('pesan-belum-pilih-supplier').classList.add('hidden');

    if (bahanItemsBaru.length === 0) {
      document.getElementById('pesan-supplier-kosong').classList.remove('hidden');
      document.getElementById('btn-tambah-item').classList.add('hidden');
      document.getElementById('item-container').innerHTML = '';
      updateTotal();
      return;
    }

    document.getElementById('pesan-supplier-kosong').classList.add('hidden');
    document.getElementById('btn-tambah-item').classList.remove('hidden');

    if (supplierBerubah === false && PEMBELIAN_AWAL && PEMBELIAN_AWAL.detail.length > 0) {
      // Prefill formulir edit: isi ulang baris sesuai data pembelian lama.
      document.getElementById('item-container').innerHTML = '';
      itemCount = 0;
      PEMBELIAN_AWAL.detail.forEach(d => tambahItem(bahanItemsBaru, d));
      updateTotal();
      return;
    }

    // Reset seluruh baris item yang sudah ada, lalu buat 1 baris baru
    // dengan daftar item yang sudah sesuai supplier terpilih.
    document.getElementById('item-container').innerHTML = '';
    itemCount = 0;
    tambahItem(bahanItemsBaru);
  }

  function tambahItem(bahanItemsUntukBaris, itemAwal) {
    const bahanItems = bahanItemsUntukBaris || bahanItemsUntukSupplier(supplierTerpilihId);
    itemCount++;
    const idx = itemCount;
    const container = document.getElementById('item-container');
    const div = document.createElement('div');
    div.className = 'flex gap-2 items-center item-row';
    div.innerHTML = `
      <div class="combo-wrap flex-1" data-name="bahan_baku_id_${idx}">
        <input type="text" class="input-field combo-input" placeholder="Cari bahan baku..." autocomplete="off">
        <input type="hidden" name="bahan_baku_id" class="combo-value bahan-select">
        <div class="combo-dropdown hidden"></div>
      </div>
      <input type="number" step="0.01" name="jumlah" min="0.01" value="${itemAwal ? itemAwal.jumlah : 1}" class="input-field w-24 jumlah-input">
      <input type="number" step="0.01" name="harga_satuan" placeholder="Harga satuan" value="${itemAwal ? itemAwal.harga_satuan : ''}" class="input-field w-32 harga-input">
      <button type="button" onclick="this.closest('.item-row').remove(); updateTotal()" class="text-warn text-sm px-2">✕</button>
    `;
    container.appendChild(div);

    initCombobox(div.querySelector(`[data-name="bahan_baku_id_${idx}"]`), bahanItems, {
      initialId: itemAwal ? itemAwal.bahan_baku_id : null,
      onSelect(item) {
        // Otomatis isi harga satuan dari harga beli terakhir supplier ini,
        // jika datanya tersedia di relasi supplier_bahan_baku.
        const relasi = SUPPLIER_BAHAN_LIST.find(sb => sb.supplier_id === supplierTerpilihId && sb.bahan_baku_id === item.id);
        const hargaInput = div.querySelector('.harga-input');
        if (relasi && relasi.harga_beli_terakhir && !hargaInput.value) {
          hargaInput.value = relasi.harga_beli_terakhir;
        }
        updateTotal();
      },
    });
    div.querySelector('.jumlah-input').addEventListener('input', updateTotal);
    div.querySelector('.harga-input').addEventListener('input', updateTotal);
  }

  function updateTotal() {
    let total = 0;
    document.querySelectorAll('.item-row').forEach(row => {
      const jumlah = Number(row.querySelector('.jumlah-input').value) || 0;
      const harga = Number(row.querySelector('.harga-input').value) || 0;
      total += jumlah * harga;
    });
    document.getElementById('display-total').textContent = 'Rp' + Math.round(total).toLocaleString('id-ID');
    updateStatusBayar(total);
  }
  function updateStatusBayar(total) {
    const dibayar = Number(document.getElementById('total_dibayar').value) || 0;
    let status = 'belum_bayar', label = 'Belum Bayar';
    if (dibayar >= total && total > 0) { status = 'lunas'; label = 'Lunas'; }
    else if (dibayar > 0 && dibayar < total) { status = 'sebagian'; label = 'Sebagian'; }
    document.getElementById('status_bayar').value = status;
    document.getElementById('display-status-bayar').value = label;
  }
  document.getElementById('total_dibayar').addEventListener('input', () => {
    const totalText = document.getElementById('display-total').textContent.replace(/[^0-9]/g, '');
    updateStatusBayar(Number(totalText) || 0);
  });

  // Saat form edit dibuka, supplier awal sudah diketahui lewat
  // PEMBELIAN_AWAL — tampilkan langsung baris item lama tanpa
  // menunggu user memilih ulang supplier di combobox.
  if (IS_EDIT && supplierTerpilihId) {
    onSupplierBerubah(false);
  }
</script>
