<% layout('layouts/main') -%>

<div class="max-w-lg">
  <div class="panel p-5">
    <% if (penjualanBelumLunas.length === 0) { %>
      <%- include('../partials/empty_state', { message: 'Tidak ada order yang belum lunas.' }) %>
    <% } else { %>
      <form action="/pembayaran/tambah" method="POST" class="space-y-4" id="form-pembayaran">
        <div>
          <label class="label-field">Order Penjualan</label>
          <div class="combo-wrap" data-name="penjualan_id">
            <input type="text" class="input-field combo-input" placeholder="Cari no. order atau nama pelanggan..." autocomplete="off">
            <input type="hidden" name="penjualan_id" id="penjualan_id" class="combo-value" required>
            <div class="combo-dropdown hidden"></div>
          </div>
        </div>

        <div>
          <label class="label-field">Sisa Tagihan</label>
          <input type="text" id="display-sisa" class="input-field bg-line/30" readonly value="Rp0">
        </div>

        <div>
          <label class="label-field">Jumlah Dibayar</label>
          <input type="number" step="0.01" name="jumlah_bayar" id="jumlah_bayar" required class="input-field">
        </div>

        <div>
          <label class="label-field">Metode Pembayaran</label>
          <select name="metode" class="input-field">
            <option value="cash">Cash</option>
            <option value="transfer">Transfer Bank</option>
            <option value="qris">QRIS</option>
            <option value="lainnya">Lainnya</option>
          </select>
        </div>

        <div>
          <label class="label-field">Catatan</label>
          <textarea name="catatan" rows="2" class="input-field"></textarea>
        </div>

        <div class="flex gap-3 pt-2">
          <button type="submit" class="btn-primary">Simpan Pembayaran</button>
          <a href="/pembayaran" class="btn-secondary">Batal</a>
        </div>
      </form>

      <script>
        const PENJUALAN_LIST = <%- JSON.stringify(penjualanBelumLunas.map(p => ({ id: p.id, nomor_order: p.nomor_order, nama: p.pelanggan ? p.pelanggan.nama : '-', sisa: p.total - p.total_dibayar }))) %>;
        const PENJUALAN_TERPILIH = <%- JSON.stringify(penjualanTerpilih || '') %>;

        const penjualanItems = PENJUALAN_LIST.map(p => ({
          id: p.id,
          label: `${p.nomor_order} · ${p.nama} (sisa Rp${Math.round(p.sisa).toLocaleString('id-ID')})`,
          searchText: `${p.nomor_order} ${p.nama}`,
          sisa: p.sisa,
        }));

        function updateSisa(sisa) {
          document.getElementById('display-sisa').value = 'Rp' + Math.round(sisa || 0).toLocaleString('id-ID');
          document.getElementById('jumlah_bayar').max = sisa || 0;
        }

        initCombobox(document.querySelector('[data-name="penjualan_id"]'), penjualanItems, {
          initialId: PENJUALAN_TERPILIH || null,
          onSelect(item) { updateSisa(item.sisa); },
        });

        if (PENJUALAN_TERPILIH) {
          const found = penjualanItems.find(p => p.id === PENJUALAN_TERPILIH);
          if (found) updateSisa(found.sisa);
        }
      </script>
    <% } %>
  </div>
</div>
