<% layout('layouts/main') -%>

<div class="space-y-6">
  
  <!-- ======================== 1. PANEL HARI INI (ATAS) ======================== -->
  <div class="panel p-5 bg-white border-l-4 border-l-gold">
    <div class="flex justify-between items-center border-b border-line pb-3 mb-4">
      <div>
        <h2 class="text-sm font-bold text-ink flex items-center gap-2">
          <span class="status-dot bg-gold animate-pulse"></span> Ringkasan Pesanan Hari Ini
        </h2>
        <p class="text-[11px] text-ink/40 mt-0.5">Daftar transaksi gogos yang masuk khusus pada hari ini.</p>
      </div>
      <a href="/penjualan/tambah" class="btn-primary text-xs">+ Penjualan Baru</a>
    </div>

    <% if (penjualanHariIni.length === 0) { %>
      <%- include('../partials/empty_state', { message: 'Belum ada transaksi penjualan untuk hari ini.', actionLabel: '+ Penjualan Baru', actionUrl: '/penjualan/tambah' }) %>
    <% } else { %>
      <div class="table-wrap">
        <table class="table-erp">
          <thead>
            <tr>
              <th>No. Order</th>
              <th>Tanggal Pesan</th>
              <th>Tanggal Kirim</th>
              <th>Pelanggan</th>
              <th>Cabang</th>
              <th class="w-64">Detail Pesanan</th> <!-- Judul kolom disesuaikan -->
              <th>Total</th>
              <th>Bayar</th>
              <th>Selesai</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% penjualanHariIni.forEach(p => { %>
              <tr class="cursor-pointer" onclick="window.location='/penjualan/<%= p.id %>'">
                <td class="font-mono text-xs"><%= p.nomor_order %></td>
                <td><%= p.tanggal_order ? new Date(p.tanggal_order).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) : '-' %></td>
                <td><%- p.tanggal_kirim ? new Date(p.tanggal_kirim).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) : '<span class="text-ink/30 italic">Belum diset</span>' %></td>
                <td><%= p.pelanggan ? p.pelanggan.nama : '-' %></td>
                <td class="text-xs text-ink/50"><%= p.cabang ? p.cabang.nama : '-' %></td>
                <td>
                  <div class="mb-1"><%- include('../partials/status_produk_pill', { status: p.status_produk }) %></div>
                  <!-- Menampilkan Rincian Item Barang -->
                  <div class="text-[11px] text-ink/70 space-y-0.5 mt-1">
                    <% if (p.penjualan_detail && p.penjualan_detail.length > 0) { %>
                      <% p.penjualan_detail.forEach(d => { %>
                        <div class="flex justify-between border-b border-ink/5 pb-0.5">
                          <span>• <%= d.produk ? d.produk.nama_produk : 'Produk' %></span>
                          <span class="font-bold text-ink"><%= d.jumlah %> pcs</span>
                        </div>
                      <% }) %>
                    <% } else { %>
                      <span class="text-ink/30 italic">Tidak ada item</span>
                    <% } %>
                  </div>
                </td>
                <td class="font-medium"><%= rupiah(p.total) %></td>
                <td><%- include('../partials/status_bayar_pill', { status: p.status_bayar }) %></td>
                <td><span class="pill <%= p.is_selesai ? 'pill-lunas' : 'pill-pending' %>"><%= p.is_selesai ? 'Selesai' : 'Berjalan' %></span></td>
                <td onclick="event.stopPropagation()">
                  <a href="/penjualan/<%= p.id %>/edit" class="text-clay text-sm font-medium hover:underline">
                    <%= currentUser.role === 'owner' ? 'Edit' : 'Ajukan Edit' %>
                  </a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

  <!-- ======================== 2. PANEL RIWAYAT & FILTER (BAWAH) ======================== -->
  <div class="panel p-5 bg-white">
    <div class="flex flex-wrap justify-between items-center gap-3 border-b border-line pb-3 mb-4">
      <div>
        <h2 class="text-sm font-semibold text-ink">Riwayat Semua Pencarian Transaksi</h2>
        <p class="text-[11px] text-ink/40 mt-0.5">Gunakan filter untuk mencari rekaman transaksi penjualan terdahulu.</p>
      </div>
      
      <form action="/penjualan" method="GET" class="flex flex-wrap items-center gap-2">
        <input type="date" name="tanggal" value="<%= filterTanggal %>" class="input-field text-xs w-40">
        
        <select name="status_bayar" class="input-field text-xs w-40">
          <option value="">Semua Status Bayar</option>
          <option value="belum_bayar" <%= filterStatusBayar === 'belum_bayar' ? 'selected' : '' %>>Belum Bayar</option>
          <option value="sebagian" <%= filterStatusBayar === 'sebagian' ? 'selected' : '' %>>Sebagian</option>
          <option value="lunas" <%= filterStatusBayar === 'lunas' ? 'selected' : '' %>>Lunas</option>
        </select>
        
        <button type="submit" class="btn-primary text-xs px-4 py-2">Filter</button>
        <% if (filterTanggal || filterStatusBayar) { %>
          <a href="/penjualan" class="btn-secondary text-xs px-3 py-2">Reset</a>
        <% } %>
      </form>
    </div>

    <% if (penjualanRiwayat.length === 0) { %>
      <p class="text-xs text-ink/40 text-center py-4">Tidak ada data transaksi riwayat yang cocok dengan kriteria filter.</p>
    <% } else { %>
      <div class="table-wrap">
        <table class="table-erp">
          <thead>
            <tr>
              <th>No. Order</th>
              <th>Tanggal Pesan</th>
              <th>Tanggal Kirim</th>
              <th>Pelanggan</th>
              <th>Cabang</th>
              <th class="w-64">Detail Pesanan</th>
              <th>Total</th>
              <th>Bayar</th>
              <th>Selesai</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% penjualanRiwayat.forEach(p => { %>
              <tr class="cursor-pointer" onclick="window.location='/penjualan/<%= p.id %>'">
                <td class="font-mono text-xs"><%= p.nomor_order %></td>
                <td><%= p.tanggal_order ? new Date(p.tanggal_order).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) : '-' %></td>
                <td><%- p.tanggal_kirim ? new Date(p.tanggal_kirim).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) : '<span class="text-ink/30 italic">Belum diset</span>' %></td>
                <td><%= p.pelanggan ? p.pelanggan.nama : '-' %></td>
                <td class="text-xs text-ink/50"><%= p.cabang ? p.cabang.nama : '-' %></td>
                <td>
                  <div class="mb-1"><%- include('../partials/status_produk_pill', { status: p.status_produk }) %></div>
                  <!-- Menampilkan Rincian Item Barang -->
                  <div class="text-[11px] text-ink/70 space-y-0.5 mt-1">
                    <% if (p.penjualan_detail && p.penjualan_detail.length > 0) { %>
                      <% p.penjualan_detail.forEach(d => { %>
                        <div class="flex justify-between border-b border-ink/5 pb-0.5">
                          <span>• <%= d.produk ? d.produk.nama_produk : 'Produk' %></span>
                          <span class="font-bold text-ink"><%= d.jumlah %> pcs</span>
                        </div>
                      <% }) %>
                    <% } else { %>
                      <span class="text-ink/30 italic">Tidak ada item</span>
                    <% } %>
                  </div>
                </td>
                <td class="font-medium"><%= rupiah(p.total) %></td>
                <td><%- include('../partials/status_bayar_pill', { status: p.status_bayar }) %></td>
                <td><span class="pill <%= p.is_selesai ? 'pill-lunas' : 'pill-pending' %>"><%= p.is_selesai ? 'Selesai' : 'Berjalan' %></span></td>
                <td onclick="event.stopPropagation()">
                  <a href="/penjualan/<%= p.id %>/edit" class="text-clay text-sm font-medium hover:underline">
                    <%= currentUser.role === 'owner' ? 'Edit' : 'Ajukan Edit' %>
                  </a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

</div>