<% layout('layouts/main') -%>

<div class="max-w-lg">
  <div class="panel p-5">
    <form action="<%= bahan ? `/master/bahan-baku/${bahan.id}/edit` : '/master/bahan-baku/tambah' %>" method="POST" class="space-y-4">
      <div>
        <label class="label-field">Kode Bahan</label>
        <input type="text" name="kode_bahan" required class="input-field" value="<%= bahan ? bahan.kode_bahan : '' %>" placeholder="BHN-001">
      </div>
      <div>
        <label class="label-field">Nama Bahan</label>
        <input type="text" name="nama_bahan" required class="input-field" value="<%= bahan ? bahan.nama_bahan : '' %>" placeholder="Tuna Segar">
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="label-field">Satuan</label>
          <input type="text" name="satuan" required class="input-field" value="<%= bahan ? bahan.satuan : '' %>" placeholder="kg">
        </div>
        <div>
          <label class="label-field">Stok Minimum</label>
          <input type="number" step="0.01" name="stok_minimum" class="input-field" value="<%= bahan ? bahan.stok_minimum : 0 %>">
        </div>
      </div>
      <% if (bahan) { %>
        <div class="flex items-center gap-2">
          <input type="checkbox" name="is_aktif" id="is_aktif" <%= bahan.is_aktif ? 'checked' : '' %> class="rounded border-line text-clay focus:ring-clay">
          <label for="is_aktif" class="text-sm text-ink">Bahan baku aktif</label>
        </div>
      <% } %>
      <div class="flex gap-3 pt-2">
        <button type="submit" class="btn-primary">Simpan</button>
        <a href="/master/bahan-baku" class="btn-secondary">Batal</a>
      </div>
    </form>
  </div>
</div>
