<% layout('layouts/main') -%>

<div class="max-w-2xl">
  <div class="panel p-5">
    <form action="<%= produk ? `/master/produk/${produk.id}/edit` : '/master/produk/tambah' %>" method="POST" class="space-y-4">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="label-field">Kode Produk</label>
          <input type="text" name="kode_produk" required class="input-field" value="<%= produk ? produk.kode_produk : '' %>" placeholder="GST-001">
        </div>
        <div>
          <label class="label-field">Kategori</label>
          <input type="text" name="kategori" class="input-field" value="<%= produk && produk.kategori ? produk.kategori : '' %>" placeholder="Gogos">
        </div>
      </div>

      <div>
        <label class="label-field">Nama Produk</label>
        <input type="text" name="nama_produk" required class="input-field" value="<%= produk ? produk.nama_produk : '' %>" placeholder="Gogos Isi Tuna">
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="label-field">Satuan</label>
          <input type="text" name="satuan" class="input-field" value="<%= produk ? produk.satuan : 'pcs' %>">
        </div>
        <div>
          <label class="label-field">Umur Simpan Frozen (hari)</label>
          <input type="number" name="umur_simpan_frozen_hari" class="input-field" value="<%= produk ? produk.umur_simpan_frozen_hari : 30 %>">
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div>
          <label class="label-field">Harga Jual Default</label>
          <input type="number" step="0.01" name="harga_jual_default" required class="input-field" value="<%= produk ? produk.harga_jual_default : 0 %>">
        </div>
        <div>
          <label class="label-field">Harga Reseller</label>
          <input type="number" step="0.01" name="harga_jual_reseller" class="input-field" value="<%= produk && produk.harga_jual_reseller ? produk.harga_jual_reseller : '' %>">
        </div>
        <div>
          <label class="label-field">Harga Stock Point</label>
          <input type="number" step="0.01" name="harga_jual_stock_point" class="input-field" value="<%= produk && produk.harga_jual_stock_point ? produk.harga_jual_stock_point : '' %>">
        </div>
      </div>

      <% if (produk) { %>
        <div class="flex items-center gap-2">
          <input type="checkbox" name="is_aktif" id="is_aktif" <%= produk.is_aktif ? 'checked' : '' %> class="rounded border-line text-clay focus:ring-clay">
          <label for="is_aktif" class="text-sm text-ink">Produk aktif</label>
        </div>
      <% } %>

      <div class="flex gap-3 pt-2">
        <button type="submit" class="btn-primary">Simpan</button>
        <a href="/master/produk" class="btn-secondary">Batal</a>
      </div>
    </form>
  </div>
</div>
