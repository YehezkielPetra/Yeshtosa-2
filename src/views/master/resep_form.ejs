<% layout('layouts/main') -%>

<div class="max-w-4xl space-y-5">
  <div class="panel p-5 bg-white">
    <h2 class="text-sm font-semibold text-ink mb-1">Pengaturan Formula Resep Masak (Sistem Batch Terpisah)</h2>
    <p class="text-xs text-ink/40">
      Dapur Yeshtosa beroperasi menggunakan 2 sub-proses memasak yang independen (Ketan &amp; Isian Ikan). 
      Silakan isi takaran adonan masak standar dan tentukan target hasil gogos (pcs) untuk masing-masing kelompok adonan di bawah ini.
    </p>
  </div>

  <div class="panel p-4 bg-cream/40 border border-line flex flex-wrap items-center justify-between gap-3 mb-5 rounded-lg">
  <div class="flex items-center gap-2">
    <span class="text-xs font-semibold text-ink/70">Salin Formula Resep dari Produk Lain:</span>
    <select id="produk_asal_copy" class="input-field text-xs w-56">
      <option value="">-- Pilih Produk Asal --</option>
      <% produkList.forEach(p => { %>
        <% if (p.id !== produk.id) { %> <option value="<%= p.id %>"><%= p.nama_produk %></option>
        <% } %>
      <% }) %>
    </select>
  </div>
  <button type="button" onclick="prosesCopyResep()" class="bg-gold text-white text-xs font-bold px-4 py-2 rounded hover:bg-gold/80 transition shadow-sm">
    ✕ Salin & Terapkan Resep
  </button>
</div>

  <form action="/master/resep/<%= produk.id %>/edit" method="POST" id="form-resep-batch" class="space-y-5">
    
    <div class="panel p-5 bg-white border-l-4 border-l-gold">
      <div class="flex flex-wrap justify-between items-center gap-3 border-b border-line pb-3 mb-4">
        <div>
          <h3 class="text-sm font-bold text-ink flex items-center gap-2">
            <span class="status-dot bg-gold"></span> 1. Kelompok Adonan Beras Ketan
          </h3>
          <p class="text-[11px] text-ink/40 mt-0.5">Masukkan takaran bahan utama ketan, santan, daun, dan bumbu ketan harian.</p>
        </div>
        <div class="w-36 shrink-0">
          <label class="text-[11px] font-semibold uppercase tracking-wide text-ink/60 block mb-1">Target Hasil (Pcs)</label>
          <input type="number" id="target_ketan_global" min="1" class="input-field text-sm font-bold text-clay text-center" placeholder="Misal: 40" oninput="sinkronkanTargetHasil()">
        </div>
      </div>

      <div class="space-y-2">
        <div class="grid grid-cols-12 gap-2 px-1 text-[11px] font-semibold uppercase tracking-wide text-ink/40 bg-cream/60 p-2 rounded">
          <div class="col-span-5">Nama Bahan Baku / Pelengkap</div>
          <div class="col-span-4">Takaran per Batch Masak</div>
          <div class="col-span-2 text-center">Target (Pcs)</div>
          <div class="col-span-1"></div>
        </div>
        <div id="ketan-container" class="space-y-2"></div>
        <button type="button" onclick="tambahBarisKetan()" class="text-clay text-xs font-medium mt-2 inline-block hover:underline">+ Tambah Bahan ke Adonan Ketan</button>
      </div>
    </div>

    <div class="panel p-5 bg-white border-l-4 border-l-clay">
      <div class="flex justify-between items-center border-b border-line pb-2 mb-3">
        <h3 class="text-sm font-semibold text-ink flex items-center gap-2"><span class="status-dot bg-clay"></span> 2. Adonan Isian Ikan Tuna</h3>
        <div class="flex items-center gap-2">
          <label class="text-xs font-semibold uppercase text-ink/60">Target Hasil (Pcs)</label>
          <input type="number" id="target_ikan_global" min="1" class="input-field text-sm w-24 text-center font-bold" value="40" oninput="sinkronisasiTargetIkan(this.value)">
        </div>
      </div>
      <p class="text-xs text-ink/40 mb-4">Masukkan takaran bahan utama ikan tuna, bawang merah, cabai, and bumbu isian pelengkap lainnya.</p>

      <div class="space-y-2">
        <div class="grid grid-cols-12 gap-2 px-1 text-xs font-semibold uppercase tracking-wide text-ink/50 bg-cream/60 p-2 rounded">
          <div class="col-span-7">Bahan Isian &amp; Bumbu Dapur</div>
          <div class="col-span-4">Takaran Masak Isian</div>
          <div class="col-span-1"></div>
        </div>
        <div id="ikan-container" class="space-y-2"></div>
      </div>
      <button type="button" onclick="tambahBarisIkan()" class="text-clay text-xs font-medium mt-2 hover:underline">+ Tambah Bahan ke Adonan Isian</button>
    </div>

    <div class="flex gap-3 pt-2">
      <button type="button" id="btn-simpan-resep" class="btn-primary">Simpan Resep Batch</button>
      <a href="/master/resep" class="btn-secondary">Batal</a>
    </div>
  </form>
</div>

<div id="kustom-confirm-modal" class="hidden fixed inset-0 bg-ink/50 flex items-center justify-center z-50">
  <div class="bg-white rounded-lg max-w-md w-full p-5 space-y-4 shadow-xl border border-line">
    <h3 class="text-sm font-bold text-ink" id="modal-confirm-title">Konfirmasi Akses</h3>
    <p class="text-xs text-ink/60" id="modal-confirm-message">Apakah Anda yakin ingin melanjutkan aksi ini?</p>
    <div class="flex justify-end gap-2 pt-2">
      <button type="button" id="modal-confirm-cancel" class="px-3 py-1.5 bg-line text-ink text-xs font-semibold rounded hover:bg-line/80">Cancel</button>
      <button type="button" id="modal-confirm-ok" class="px-4 py-1.5 bg-gold text-white text-xs font-bold rounded hover:bg-gold/80">OK</button>
    </div>
  </div>
</div>

<script>
  const BAHAN_LIST = <%- JSON.stringify(bahanList) %>;
  // Membaca data awal termasuk kolom tipe_blok dari database
  const RESEP_AWAL = <%- JSON.stringify((produk.resep_produk || []).map(r => ({
    bahan_baku_id: r.bahan_baku_id,
    nama_bahan: r.bahan_baku ? r.bahan_baku.nama_bahan.toLowerCase() : '',
    jumlah_per_batch: r.jumlah_per_batch || r.jumlah_per_unit || '',
    target_hasil_pcs: r.target_hasil_pcs || 40,
    tipe_blok: r.tipe_blok || '' // Menangkap kolom tipe_blok lama
  }))) %>;

  function bahanOptionsHtml(selectedId) {
    return '<option value="">Pilih bahan...</option>' + BAHAN_LIST.map(b =>
      `<option value="${b.id}" data-satuan="${b.satuan}" ${b.id === selectedId ? 'selected' : ''}>${b.nama_bahan} (${b.satuan})</option>`
    ).join('');
  }

  // Menambahkan baris ke Kelompok Adonan Beras Ketan
  function tambahBarisKetan(bahanBakuId, jmlBatch, targetHasil) {
    const container = document.getElementById('ketan-container');
    if (!container) return;
    
    const div = document.createElement('div');
    div.className = 'grid grid-cols-12 gap-2 items-center resep-row bg-white p-1 rounded border border-line/40';
    
    const currentTarget = targetHasil || currentTargetKetan();

    // FIX 1: Menyisipkan input hidden name="tipe_blok[]" bernilai 'nasi'
    div.innerHTML = `
      <input type="hidden" name="tipe_blok[]" value="nasi">
      <div class="col-span-5">
        <select name="bahan_baku_id[]" class="input-field w-full text-sm" required onchange="updateSatuanLabel(this)">
          ${bahanOptionsHtml(bahanBakuId || '')}
        </select>
      </div>
      <div class="col-span-4 flex items-center gap-1.5">
        <input type="number" step="0.0001" name="jumlah_per_batch[]" min="0.0001" value="${jmlBatch || ''}" placeholder="Takaran" class="input-field text-sm" required>
        <span class="text-xs text-ink/40 w-12 truncate satuan-label">-</span>
      </div>
      <div class="col-span-2">
        <input type="number" name="target_hasil_pcs[]" value="${currentTarget}" readonly class="input-field text-sm bg-line/20 font-semibold text-center select-target-ketan">
      </div>
      <div class="col-span-1 text-center">
        <button type="button" onclick="this.closest('.resep-row').remove()" class="text-warn text-sm p-1 hover:bg-warn/5 rounded">✕</button>
      </div>
    `;
    container.appendChild(div);
    updateSatuanLabel(div.querySelector('select'));
  }

  // Menambah baris ke kelompok Adonan Isian Ikan
  function tambahBarisIkan(bahanBakuId, jmlBatch) {
    const container = document.getElementById('ikan-container');
    if (!container) return;
    
    const div = document.createElement('div');
    div.className = 'grid grid-cols-12 gap-2 items-center resep-row bg-white p-1 rounded border border-line/40';
    const currentTargetIkan = document.getElementById('target_ikan_global').value || 40;

    // FIX 2: Menyisipkan input hidden name="tipe_blok[]" bernilai 'ikan'
    // PENTING: Tambahkan tanda [] pada name="bahan_baku_id", "jumlah_per_batch", dan "target_hasil_pcs" 
    // agar data terkirim sebagai array yang sejajar ke backend Express Anda.
    div.innerHTML = `
      <input type="hidden" name="tipe_blok[]" value="ikan">
      <div class="col-span-7">
        <select name="bahan_baku_id[]" class="input-field w-full text-sm" required onchange="updateSatuanLabel(this)">
          ${bahanOptionsHtml(bahanBakuId || '')}
        </select>
      </div>
      <div class="col-span-4 flex items-center gap-1.5">
        <input type="number" step="0.0001" name="jumlah_per_batch[]" min="0.0001" value="${jmlBatch || ''}" placeholder="Takaran" class="input-field text-sm" required>
        <span class="text-xs text-ink/40 w-12 truncate satuan-label">-</span>
        <input type="hidden" name="target_hasil_pcs[]" class="select-target-ikan" value="${currentTargetIkan}">
      </div>
      <div class="col-span-1 text-center">
        <button type="button" onclick="this.closest('.resep-row').remove()" class="text-warn text-sm p-1 hover:bg-warn/5 rounded">✕</button>
      </div>
    `;
    container.appendChild(div);
    updateSatuanLabel(div.querySelector('select'));
  }

  function currentTargetKetan() {
    return document.getElementById('target_ketan_global').value || 40;
  }

  function sinkronkanTargetHasil() {
    const val = currentTargetKetan();
    document.querySelectorAll('.select-target-ketan').forEach(input => {
      input.value = val;
    });
  }

  function sinkronisasiTargetIkan(val) {
    document.querySelectorAll('.select-target-ikan').forEach(input => {
      input.value = val || 40;
    });
  }

  function updateSatuanLabel(selectEl) {
    if(!selectEl) return;
    const opt = selectEl.selectedOptions[0];
    const row = selectEl.closest('.resep-row');
    if (!row) return;
    const label = row.querySelector('.satuan-label');
    if (!label) return;
    if (opt && opt.dataset.satuan) {
      label.textContent = opt.dataset.satuan;
    } else {
      label.textContent = '-';
    }
  }

  // FIX 3: Logika pembagian data cerdas berdasarkan kolom `tipe_blok` asli dari database
  if (RESEP_AWAL.length > 0) {
    const itemKetanAwal = RESEP_AWAL.find(r => r.nama_bahan.includes('beras') || r.nama_bahan.includes('ketan'));
    if (itemKetanAwal) {
      document.getElementById('target_ketan_global').value = itemKetanAwal.target_hasil_pcs;
    } else {
      document.getElementById('target_ketan_global').value = RESEP_AWAL[0].target_hasil_pcs;
    }

    const itemIkanAwal = RESEP_AWAL.find(r => r.nama_bahan.includes('tuna') || r.nama_bahan.includes('ikan'));
    if (itemIkanAwal) {
      document.getElementById('target_ikan_global').value = itemIkanAwal.target_hasil_pcs;
    }

    RESEP_AWAL.forEach(r => {
      // Jika database sudah memiliki data tipe_blok, gunakan itu sebagai acuan utama
      if (r.tipe_blok === 'nasi') {
        tambahBarisKetan(r.bahan_baku_id, r.jumlah_per_batch, r.target_hasil_pcs);
      } else if (r.tipe_blok === 'ikan') {
        tambahBarisIkan(r.bahan_baku_id, r.jumlah_per_batch);
      } else {
        // Fallback cadangan jika ada data lama yang kolom tipe_blok-nya masih kosong
        if (r.nama_bahan.includes('beras') || r.nama_bahan.includes('ketan') || r.nama_bahan.includes('santan') || r.nama_bahan.includes('daun')) {
          tambahBarisKetan(r.bahan_baku_id, r.jumlah_per_batch, r.target_hasil_pcs);
        } else {
          tambahBarisIkan(r.bahan_baku_id, r.jumlah_per_batch);
        }
      }
    });
  } else {
    document.getElementById('target_ketan_global').value = 40;
    tambahBarisKetan();
    tambahBarisIkan();
  }

async function prosesCopyResep() {
  const produkAsalId = document.getElementById('produk_asal_copy').value;
  if (!produkAsalId) return alert("Silakan pilih produk asal terlebih dahulu!");

  // Menggunakan Modal Kustom Anda yang sudah berjalan normal
  bukaModalKustom(
    "Salin Formula Resep", 
    "Menyalin resep akan mengosongkan takaran yang sedang tampil di layar saat ini. Lanjutkan?", 
    async function() {
      try {
        const response = await fetch(`/master/resep/api/${produkAsalId}`);
        const result = await response.json();

        if (!result.success) throw new Error(result.message);
        if (!result.resep || result.resep.length === 0) return alert("Produk asal belum memiliki formula resep.");

        // 1. Bersihkan layar saat ini dari isian lama
        document.getElementById('ketan-container').innerHTML = '';
        document.getElementById('ikan-container').innerHTML = '';

        // 2. Ambil nilai target hasil global dari produk asal
        const itemKetan = result.resep.find(r => {
          const blok = (r.tipe_blok || '').toLowerCase();
          const nama = r.bahan_baku ? (r.bahan_baku.nama_bahan || '').toLowerCase() : '';
          return blok === 'nasi' || nama.includes('beras') || nama.includes('ketan');
        });
        if (itemKetan) document.getElementById('target_ketan_global').value = itemKetan.target_hasil_pcs;
        
        const itemIkan = result.resep.find(r => {
          const blok = (r.tipe_blok || '').toLowerCase();
          const nama = r.bahan_baku ? (r.bahan_baku.nama_bahan || '').toLowerCase() : '';
          return blok === 'ikan' || nama.includes('tuna') || nama.includes('ikan');
        });
        if (itemIkan) document.getElementById('target_ikan_global').value = itemIkan.target_hasil_pcs || 40;

        // 3. Masukkan baris baru dengan validasi toleransi huruf besar/kecil (Case-Insensitive)
        result.resep.forEach(r => {
          // Normalisasi teks agar aman dari perbedaan kapitalisasi data lama
          const blokClean = (r.tipe_blok || '').toLowerCase().trim();
          const namaBahanClean = r.bahan_baku ? (r.bahan_baku.nama_bahan || '').toLowerCase() : '';

          if (blokClean === 'nasi') {
            tambahBarisKetan(r.bahan_baku_id, r.jumlah_per_batch, r.target_hasil_pcs);
          } else if (blokClean === 'ikan') {
            tambahBarisIkan(r.bahan_baku_id, r.jumlah_per_batch);
          } else {
            // CADANGAN: Jika tipe_blok kosong/null di database, deteksi lewat nama bahannya
            if (namaBahanClean.includes('beras') || namaBahanClean.includes('ketan') || namaBahanClean.includes('santan') || namaBahanClean.includes('daun')) {
              tambahBarisKetan(r.bahan_baku_id, r.jumlah_per_batch, r.target_hasil_pcs);
            } else {
              tambahBarisIkan(r.bahan_baku_id, r.jumlah_per_batch);
            }
          }
        });

        alert("Resep berhasil disalin ke layar! Silakan sesuaikan takaran bumbu ukuran baru ini, lalu klik Simpan Resep Batch.");
      } catch (err) {
        console.error("Gagal memproses copy resep:", err);
        alert("Gagal menyalin resep: " + err.message);
      }
    }
  );
}

function bukaModalKustom(title, message, onConfirm) {
  const modal = document.getElementById('kustom-confirm-modal');
  document.getElementById('modal-confirm-title').textContent = title;
  document.getElementById('modal-confirm-message').textContent = message;
  
  modal.classList.remove('hidden');
  
  // Reset event listener agar tidak menumpuk saat dipanggil berkali-kali
  const btnOk = document.getElementById('modal-confirm-ok');
  const btnCancel = document.getElementById('modal-confirm-cancel');
  
  btnOk.onclick = function() {
    modal.classList.add('hidden');
    onConfirm();
  };
  
  btnCancel.onclick = function() {
    modal.classList.add('hidden');
  };
}

document.getElementById('btn-simpan-resep').addEventListener('click', function() {
  bukaModalKustom(
    "Simpan Formula Resep",
    "Apakah Anda yakin data formula resep batch yang diisi sudah benar dan ingin menyimpannya ke database?",
    function() {
      // Jika user klik OK, jalankan submit form secara resmi
      document.getElementById('form-resep-batch').submit();
    }
  );
});
</script>