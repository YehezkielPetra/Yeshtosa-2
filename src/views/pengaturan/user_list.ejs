<% layout('layouts/main') -%>

<div class="panel">
  <div class="flex items-center justify-between p-4 border-b border-line">
    <h2 class="text-sm font-semibold text-ink">Daftar Pengguna</h2>
    <a href="/pengaturan/users/tambah" class="btn-primary text-sm">+ Tambah Pengguna</a>
  </div>
  <% if (userList.length === 0) { %>
    <%- include('../partials/empty_state', { message: 'Belum ada pengguna lain.', actionLabel: '+ Tambah Pengguna', actionUrl: '/pengaturan/users/tambah' }) %>
  <% } else { %>
    <div class="table-wrap">
<table class="table-erp">
      <thead><tr><th>Nama</th><th>Role</th><th>Cabang</th><th>Status</th><th></th></tr></thead>
      <tbody>
        <% userList.forEach(u => { %>
          <tr>
            <td class="font-medium"><%= u.nama %></td>
            <td><span class="pill pill-fresh capitalize"><%= u.role %></span></td>
            <td class="text-xs text-ink/50"><%= u.cabang ? u.cabang.nama : '-' %></td>
            <td><span class="pill <%= u.is_aktif ? 'pill-lunas' : 'pill-belum' %>"><%= u.is_aktif ? 'Aktif' : 'Nonaktif' %></span></td>
            <td><a href="/pengaturan/users/<%= u.id %>/edit" class="text-clay text-sm font-medium hover:underline">Edit</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
</div>
  <% } %>
</div>
