<% layout('layouts/main') -%>

<div class="panel">
  <div class="flex items-center justify-between p-4 border-b border-line">
    <h2 class="text-sm font-semibold text-ink">Daftar Produksi</h2>
    <div class="flex gap-2">
      <a href="/produksi/konversi-frozen" class="btn-secondary text-sm">Konversi ke Frozen</a>
      <a href="/produksi/tambah" class="btn-primary text-sm">+ Catat Produksi</a>
    </div>
  </div>
  <% if (produksiList.length === 0) { %>
    <%- include('../partials/empty_state', { message: 'Belum ada catatan produksi.', actionLabel: '+ Catat Produksi', actionUrl: '/produksi/tambah' }) %>
  <% } else { %>
    <div class="table-wrap">
    <table class="table-erp">
      <thead><tr><th>No. Produksi</th><th>Tanggal</th><th>Cabang</th><th>Hasil</th><th>Item</th><th>Biaya Bahan (HPP)</th><th></th></tr></thead>
      <tbody>
        <% produksiList.forEach(p => { %>
          <tr>
            <td class="font-mono text-xs"><%= p.nomor_produksi %></td>
            <td class="text-xs"><%= tanggalIndo(p.tanggal_produksi) %></td>
            <td class="text-xs text-ink/50"><%= p.cabang ? p.cabang.nama : '-' %></td>
            <td><%- include('../partials/status_produk_pill', { status: p.status_hasil }) %></td>
            <td class="text-xs">
              <% (p.produksi_detail || []).forEach(d => { %>
                <span class="inline-block mr-2"><%= d.produk ? d.produk.nama_produk : '-' %> ×<%= d.jumlah %></span>
              <% }) %>
            </td>
            <td class="font-medium text-warn"><%= rupiah(p.total_biaya_bahan) %></td>
            <td class="whitespace-nowrap">
              <a href="/produksi/<%= p.id %>/edit" class="text-clay text-sm font-medium hover:underline mr-3">Edit</a>
              
              <form action="/produksi/<%= p.id %>/batalkan" method="POST" class="inline form-hapus-produksi">
                <input type="hidden" name="alasan" class="alasan-input">
                <button type="button" onclick="prosesHapusProduksi(this)" class="text-warn text-sm font-medium hover:underline">Hapus</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    </div>
  <% } %>
</div>

<div id="kustom-confirm-modal" class="hidden fixed inset-0 flex items-center justify-center p-4 bg-black/60" style="z-index: 999999 !important; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;">
  <div class="bg-white rounded-lg max-w-md w-full p-6 space-y-4 shadow-2xl border border-line">
    <h3 class="text-sm font-bold text-ink" id="modal-confirm-title">Konfirmasi Hapus</h3>
    <p class="text-xs text-ink/60 leading-relaxed" id="modal-confirm-message">Apakah Anda yakin ingin menghapus data ini?</p>
    
    <div class="space-y-1">
      <label class="text-[11px] font-semibold uppercase tracking-wide text-ink/50 block">Alasan Penghapusan (Opsional):</label>
      <input type="text" id="modal-confirm-alasan" class="input-field text-xs w-full" placeholder="Misal: Salah input kuantitas adonan">
    </div>

    <div style="display: flex !important; justify-content: flex-end !important; align-items: center !important; gap: 8px !important; padding-top: 16px !important; border-top: 1px solid rgba(0,0,0,0.1) !important; margin-top: 8px !important;">
      
      <button type="button" id="modal-confirm-cancel" class="px-4 py-2 bg-line text-ink text-xs font-semibold rounded hover:bg-line/80 transition cursor-pointer">
        Cancel
      </button>
      
      <button type="button" id="modal-confirm-ok" class="rounded transition cursor-pointer" 
              style="display: inline-block !important; 
                     visibility: visible !important; 
                     opacity: 1 !important; 
                     background-color: #dc2626 !important; 
                     color: #ffffff !important; 
                     padding: 8px 20px !important; 
                     font-size: 12px !important; 
                     font-weight: 700 !important; 
                     border: none !important;
                     min-width: 80px !important;
                     text-align: center !important;">
        Hapus
      </button>

    </div>
  </div>
</div>

<script>
const kustomModalEl = document.getElementById('kustom-confirm-modal');
const modalInputAlasan = document.getElementById('modal-confirm-alasan');
const modalBtnOk = document.getElementById('modal-confirm-ok');
const modalBtnCancel = document.getElementById('modal-confirm-cancel');

let formProduksiAktif = null;

function prosesHapusProduksi(buttonEl) {
  formProduksiAktif = buttonEl.closest('.form-hapus-produksi');
  
  if(modalInputAlasan) modalInputAlasan.value = '';

  document.getElementById('modal-confirm-title').textContent = "Hapus Catatan Produksi";
  document.getElementById('modal-confirm-message').textContent = "Yakin ingin menghapus produksi ini? Stok bahan baku dan produk yang terpengaruh akan otomatis dikembalikan ke gudang.";
  
  if(kustomModalEl) kustomModalEl.classList.remove('hidden');
}

if (modalBtnOk) {
  modalBtnOk.addEventListener('click', function() {
    if (kustomModalEl) kustomModalEl.classList.add('hidden');
    
    if (formProduksiAktif) {
      const alasanTeks = modalInputAlasan ? modalInputAlasan.value.trim() : '';
      formProduksiAktif.querySelector('.alasan-input').value = alasanTeks;
      formProduksiAktif.submit();
    }
  });
}

if (modalBtnCancel) {
  modalBtnCancel.addEventListener('click', function() {
    if (kustomModalEl) kustomModalEl.classList.add('hidden');
    formProduksiAktif = null;
  });
}
</script>