{
  "name": "yeshtosa-erp",
  "version": "1.0.0",
  "description": "Yeshtosa ERP - Business Management System",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "build": "npm run build:css",
    "postinstall": "npm run build:css",
    "build:css": "tailwindcss -i ./src/styles/input.css -o ./public/css/style.css --minify",
    "watch:css": "tailwindcss -i ./src/styles/input.css -o ./public/css/style.css --watch"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "bcryptjs": "^2.4.3",
    "connect-flash": "^0.1.1",
    "cookie-parser": "^1.4.6",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "ejs-mate": "^4.0.0",
    "express": "^4.21.0",
    "express-session": "^1.18.0",
    "express-validator": "^7.2.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "method-override": "^3.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "tailwindcss": "^3.4.10",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
