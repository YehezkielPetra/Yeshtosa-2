# ============================================================
# YESHTOSA ERP - Environment Variables
# Salin file ini ke .env dan isi dengan nilai sebenarnya.
# JANGAN PERNAH commit file .env ke Git / GitHub.
# ============================================================

# --- Supabase ---
# Didapat dari: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=isi_dengan_service_role_key_anda
SUPABASE_ANON_KEY=isi_dengan_anon_key_anda

# --- Session ---
# Generate string acak panjang, contoh: openssl rand -base64 32
SESSION_SECRET=ganti_dengan_string_acak_yang_panjang_dan_aman

# --- App ---
NODE_ENV=production
PORT=3000
APP_NAME=Yeshtosa ERP

# Set jadi 'true' HANYA jika aplikasi diakses lewat HTTPS asli (di hosting production).
# Biarkan 'false' atau hapus baris ini saat development lokal (http://localhost),
# karena browser akan menolak menyimpan cookie 'secure' di koneksi non-HTTPS.
FORCE_SECURE_COOKIE=false

# --- Cabang default untuk seed data (opsional) ---
DEFAULT_TIMEZONE=Asia/Makassar
